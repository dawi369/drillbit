{
  "expo": {
    "name": "drillbit",
    "slug": "drillbit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "scheme": "drillbit",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "icon": "./assets/logo.png",
      "bundleIdentifier": "dawi.drillbit",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo_transparent.png",
        "backgroundColor": "#0F0F0F"
      },
      "package": "dawi.drillbit"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0F0F0F",
          "image": "./assets/logo_transparent.png",
          "imageWidth": 200,
          "android": {
            "image": "./assets/logo_transparent.png",
            "imageWidth": 200
          }
        }
      ],
      "expo-secure-store",
      "expo-sqlite",
      [
        "expo-widgets",
        {
          "bundleIdentifier": "dawi.drillbit.widget",
          "groupIdentifier": "group.dawi.drillbit",
          "enablePushNotifications": false,
          "frequentUpdates": false,
          "widgets": [
            {
              "name": "drillbitWidget",
              "displayName": "drillbit",
              "description": "Daily interview prep at a glance.",
              "supportedFamilies": [
                "systemSmall",
                "systemMedium",
                "systemLarge"
              ],
              "contentMarginsDisabled": false
            }
          ]
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "ExpoWidgetsTarget",
                  "bundleIdentifier": "dawi.drillbit.widget",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.dawi.drillbit"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "cc064f5b-a366-4789-9350-33b1fc091655"
      }
    },
    "owner": "dawi369"
  }
}
