{
  "expo": {
    "name": "drillbit",
    "slug": "drillbit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "drillbit",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.dawi369.drillbit"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.dawi369.drillbit"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#000000",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store",
      "expo-sqlite",
      [
        "expo-widgets",
        {
          "bundleIdentifier": "com.dawi369.drillbit.ExpoWidgetsTarget",
          "groupIdentifier": "group.com.dawi369.drillbit",
          "enablePushNotifications": false,
          "frequentUpdates": false,
          "widgets": [
            {
              "name": "DrillbitWidget",
              "displayName": "Drillbit",
              "description": "Daily interview prep at a glance.",
              "supportedFamilies": [
                "systemSmall",
                "systemMedium",
                "systemLarge"
              ],
              "contentMarginsDisabled": false
            }
          ]
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "ExpoWidgetsTarget",
                  "bundleIdentifier": "com.dawi369.drillbit.ExpoWidgetsTarget",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.dawi369.drillbit"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "cc064f5b-a366-4789-9350-33b1fc091655"
      }
    },
    "owner": "dawi369"
  }
}
